BIOTARGET_ENV=dev
LOG_LEVEL=INFO

# Literature embeddings (sentence-transformers). For PubMed-tuned vectors (build plan):
# BIOTARGET_EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO
BIOTARGET_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional local model endpoint for OSS-first mode
LOCAL_MODEL_BASE_URL=
LOCAL_MODEL_NAME=

# Optional provider keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Public biomedical API tuning
NCBI_EMAIL=
NCBI_API_KEY=
OMIM_API_KEY=
REQUEST_TIMEOUT_SECONDS=

# Hugging Face Hub (sentence-transformers / Chroma downloads): avoids unauthenticated
# hub warnings and raises rate limits. Same value as HUGGINGFACE_HUB_TOKEN if you use that name.
HF_TOKEN=

# Optional tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
